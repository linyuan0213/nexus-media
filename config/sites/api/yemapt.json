{
  "id": "yemapt",
  "name": "YemaPT",
  "domain": "www.yemapt.org",
  "domain_aliases": [
    "yemapt.org"
  ],
  "tid_pattern": "\\d+",
  "detail_page_url": "/api/torrent/fetchTorrentDetail?id={tid}&firstView=false",
  "encoding": "UTF-8",
  "public": false,
  "api": {
    "base_url": "https://www.yemapt.org",
    "auth": {
      "type": "cookie"
    },
    "endpoints": {
      "search": {
        "method": "POST",
        "path": "/api/torrent/fetchOpenTorrentList",
        "body": {
          "keyword": "{keyword}",
          "pageParam": {
            "current": "{page_1}",
            "pageSize": 20,
            "total": 0,
            "pageSizeOptions": [
              "10",
              "20",
              "40"
            ],
            "size": "small"
          },
          "sorter": {}
        },
        "mode_mapping": {
          "MOVIE": [
            {
              "categoryId": 4
            }
          ],
          "TV": [
            {
              "categoryId": 5
            },
            {
              "categoryId": 13
            },
            {
              "categoryId": 15
            }
          ],
          "ANIME": [
            {
              "categoryId": 14
            }
          ]
        },
        "response": {
          "items_key": "data",
          "item_mapping": {
            "title": {
              "source": "showName"
            },
            "description": {
              "source": "shortDesc"
            },
            "size": {
              "source": "fileSize"
            },
            "seeders": {
              "source": "seedNum"
            },
            "leechers": {
              "source": "leechNum"
            },
            "grabs": {
              "source": "completedNum"
            },
            "pubdate": {
              "source": "listingTime",
              "transform": "utc_to_local"
            },
            "downloadvolumefactor": {
              "type": "mapping",
              "source": "downloadPromotion",
              "map": {
                "free": 0.0,
                "NORMAL": 1.0
              }
            },
            "uploadvolumefactor": {
              "type": "constant",
              "value": 1.0
            },
            "labels": {
              "source": "tagList",
              "transform": "yemapt_labels"
            },
            "page_url": {
              "type": "template",
              "value": "https://{domain}/api/torrent/fetchTorrentDetail?id={tid}&firstView=false",
              "fields": {
                "tid": "id"
              }
            }
          }
        }
      },
      "detail": {
        "method": "GET",
        "path": "/api/torrent/fetchTorrentDetail",
        "params": {
          "id": "{tid}",
          "firstView": "false"
        }
      },
      "test_connection": {
        "method": "POST",
        "path": "/api/torrent/fetchOpenTorrentList",
        "body": {
          "keyword": "",
          "pageParam": {
            "current": 1,
            "pageSize": 1,
            "pageSizeOptions": [
              "10"
            ],
            "size": "small"
          },
          "sorter": {}
        }
      },
      "user_info": {
        "method": "GET",
        "path": "/api/user/profile"
      }
    }
  },
  "user_info": {
    "type": "api",
    "profile": {
      "method": "GET",
      "path": "/api/user/profile",
      "response": {
        "field_mapping": {
          "username": {
            "source": "data.name"
          },
          "upload": {
            "source": "data.promotionUploadSize",
            "type": "int"
          },
          "download": {
            "source": "data.promotionDownloadSize",
            "type": "int"
          },
          "bonus": {
            "source": "data.bonus",
            "type": "float"
          },
          "user_level": {
            "source": "data.level",
            "transform": "map_value",
            "map": {
              "1": "Lv.1",
              "2": "Lv.2",
              "3": "Lv.3",
              "4": "Lv.4",
              "5": "Lv.5",
              "6": "Lv.6",
              "7": "Lv.7",
              "8": "Lv.8"
            }
          },
          "join_at": {
            "source": "data.registerTime",
            "transform": "utc_to_local"
          }
        }
      }
    },
    "seeding": {
      "method": "POST",
      "path": "/api/userTorrent/fetchSeedTorrentInfo",
      "body": {},
      "response": {
        "response_type": "single",
        "items_key": "data",
        "seeders_field": "num",
        "size_field": "fileSize"
      }
    }
  },
  "torrent_attr": {
    "method": "GET",
    "path": "/api/torrent/fetchTorrentDetail?id={tid}&firstView=false",
    "response": {
      "free_key": "data.downloadPromotion",
      "free_value": "free",
      "peer_count_key": "data.seedNum"
    }
  },
  "download": {
    "type": "api_chained",
    "method": "GET",
    "path": "/api/torrent/generateDownloadKey?id={tid}",
    "response_key": "data",
    "download_url": "{base}/api/torrent/download1?token={token}"
  },
  "favicon": "data:image/svg+xml;base64,"
}