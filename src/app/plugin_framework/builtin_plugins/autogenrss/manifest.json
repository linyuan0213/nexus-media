{
  "manifest_version": "1.0",
  "id": "autogenrss",
  "name": "RSS自动生成",
  "version": "1.0",
  "author": "linyuan0213",
  "author_url": "https://github.com/linyuan0213",
  "description": "RSS自动生成",
  "category": "site",
  "tags": ["RSS", "站点"],
  "icon": "lucide:rss",
  "color": "#bef264",
  "min_app_version": "3.0.0",
  "backend": {
    "entry": "backend.plugin:AutoGenRssPlugin",
    "api_prefix": "/api/plugin/autogenrss",
    "permissions": [],
    "hooks": [
      "plugin.config_changed"
    ],
    "supports_run": true
  },
  "frontend": {
    "routes": [],
    "settings": {
      "component": "SettingsPage",
      "fields": [
        {
          "key": "enabled",
          "type": "switch",
          "label": "开启定时生成RSS",
          "default": false,
          "help": "开启后会根据周期定时生成指定站点RSS"
        },
        {
          "key": "rss_sites",
          "type": "multi_select",
          "label": "生成RSS站点",
          "source": "sites",
          "default": [],
          "help": "选择需要生成RSS的站点"
        },
        {
          "key": "notify",
          "type": "switch",
          "label": "运行时通知",
          "default": false,
          "help": "运行生成RSS任务后会发送通知"
        },
        {
          "key": "cron",
          "type": "cron",
          "label": "运行周期",
          "default": "0 0 * * *",
          "placeholder": "0 0 * * *",
          "help": "设置自动同步时间周期，支持5位cron表达式"
        }
      ]
    },
    "slots": []
  }
}
