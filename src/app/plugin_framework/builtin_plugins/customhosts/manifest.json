{
  "manifest_version": "1.0",
  "id": "customhosts",
  "name": "自定义Hosts",
  "version": "1.0",
  "author": "linyuan0213",
  "author_url": "https://github.com/linyuan0213",
  "description": "应用层 DNS 映射，无需 root 权限，仅对当前进程生效。",
  "category": "system",
  "tags": ["hosts", "DNS", "网络"],
  "icon": "lucide:globe",
  "color": "#06b6d4",
  "min_app_version": "4.0.0",
  "backend": {
    "entry": "backend.plugin:CustomHostsPlugin",
    "api_prefix": "/api/plugin/customhosts",
    "permissions": [],
    "hooks": [
      "plugin.config_changed"
    ],
    "supports_run": false
  },
  "frontend": {
    "routes": [],
    "settings": {
      "component": "SettingsPage",
      "fields": [
        {
          "key": "enable",
          "type": "switch",
          "label": "开启hosts同步",
          "default": false,
          "help": "开启后将自定义DNS映射注入到所有HTTP请求中，无需系统权限"
        },
        {
          "key": "hosts",
          "type": "textarea",
          "label": "DNS 配置",
          "default": "",
          "placeholder": "每行一个配置，格式为：ip host1 host2 ...\n示例：1.2.3.4 pt.example.com",
          "help": "IP 后跟一个或多个域名，空格分隔。仅对 Nexus Media 自身流量生效。"
        }
      ]
    },
    "slots": []
  }
}
